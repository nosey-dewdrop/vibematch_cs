# copy this file to "credentials.properties" (same folder) and fill it in to
# send real verification emails. the real file is gitignored so your password
# never gets committed.
#
# for gmail you need an "app password", not your normal password:
# google account -> security -> 2 step verification -> app passwords
# (2 step verification has to be ON first, then app passwords shows up)

email.sender=youraddress@gmail.com
email.password=your_gmail_app_password
email.smtp.host=smtp.gmail.com
email.smtp.port=587

# spotify: connect a user's account to match on their music taste.
# make an app at developer.spotify.com/dashboard, add this exact redirect uri:
#   http://127.0.0.1:8888/callback
# tick "Web API", then paste the Client ID below. no client secret needed
# (we use the PKCE flow, which is the right one for a desktop app).
spotify.client.id=your_spotify_client_id
